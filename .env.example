# ============================================
# CareCircle Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --------------------------------------------
# Database
# --------------------------------------------
# PostgreSQL connection string (e.g., Neon, Supabase, or local PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/nurse_workforce?sslmode=require"

# --------------------------------------------
# Auth (Auth.js / NextAuth)
# --------------------------------------------
# Secret used to sign/encrypt tokens. Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# The canonical URL of your app (used for OAuth callbacks)
AUTH_URL="http://localhost:3000"

# Optional: OAuth providers (uncomment and fill in to enable)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# --------------------------------------------
# App
# --------------------------------------------
# Public-facing app name (exposed to the browser via NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_APP_NAME="CareCircle"
# Public-facing app URL (exposed to the browser via NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --------------------------------------------
# AI / API Keys
# --------------------------------------------
# Anthropic API key for Claude AI integration
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
